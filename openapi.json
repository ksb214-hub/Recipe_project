{
  "openapi": "3.0.0",
  "info": {
    "title": "연습용 Petstore API",
    "version": "1.0.0"
  },
  "paths": {
    "/pets": {
      "get": {
        "summary": "모든 애완동물 목록 조회",
        "operationId": "listPets",
        "responses": {
          "200": {
            "description": "성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Pets" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pet": {
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "tag": { "type": "string" }
        }
      },
      "Pets": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/Pet" }
      }
    }
  }
}